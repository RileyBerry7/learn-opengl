# Version 2 - Low Poly Teapot

# 12 positions (adding a simple spout and handle)
v -0.5 -0.5  0.5
v -0.5  0.5  0.5
v  0.5  0.5  0.5
v  0.5 -0.5  0.5
v -0.5 -0.5 -0.5
v -0.5  0.5 -0.5
v  0.5  0.5 -0.5
v  0.5 -0.5 -0.5
v  0.0  0.6  0.0   # top center
v  0.0 -0.6  0.0   # bottom center
v  0.6  0.0  0.0   # spout tip
v -0.6  0.0  0.0   # handle tip

# 8 UVs
vt 0.0 0.0
vt 0.0 1.0
vt 1.0 1.0
vt 1.0 0.0
vt 0.5 1.0
vt 0.5 0.0
vt 1.0 0.5
vt 0.0 0.5

# Base cube faces (body)
f 1/1 2/2 3/3 4/4
f 8/4 7/3 6/2 5/1
f 5/1 6/2 2/3 1/4
f 4/1 3/2 7/3 8/4
f 2/1 6/2 7/3 3/4
f 1/1 4/4 8/3 5/2

# Top/bottom center triangles (lid & bottom)
f 2/5 3/5 9/5
f 3/5 7/5 9/5
f 7/5 6/5 9/5
f 6/5 2/5 9/5
f 1/6 5/6 10/6
f 5/6 8/6 10/6
f 8/6 4/6 10/6
f 4/6 1/6 10/6

# Spout (simple triangle)
f 3/7 7/7 11/7
f 4/7 3/7 11/7
f 8/7 4/7 11/7
f 7/7 8/7 11/7

# Handle (simple triangle)
f 2/8 6/8 12/8
f 6/8 5/8 12/8
f 1/8 2/8 12/8
f 5/8 1/8 12/8